---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kulan Thamuditha | Software Engineer</title>
    <style>
      /* Custom Animations */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-12px); }
        100% { transform: translateY(0px); }
      }
      .animate-fade-in {
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      .animate-float {
        animation: float 6s ease-in-out infinite;
      }
      /* New continuous float class for cards */
      .card-float {
        animation: float 6s ease-in-out infinite;
      }
      .delay-float-1 { animation-delay: 0s; }
      .delay-float-2 { animation-delay: 1.5s; }
      .delay-float-3 { animation-delay: 3s; }

      .delay-100 { animation-delay: 100ms; }
      .delay-200 { animation-delay: 200ms; }
      .delay-300 { animation-delay: 300ms; }
      .delay-400 { animation-delay: 400ms; }
      
      /* Glassmorphism utilities */
      .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.5);
      }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased selection:bg-blue-200 selection:text-blue-900">
    
    <!-- Navigation -->
    <nav class="fixed w-full bg-white/80 backdrop-blur-lg border-b border-slate-200 z-50 transition-all duration-300">
      <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="#" class="text-3xl font-black tracking-tighter transition-transform duration-300 hover:scale-105">
  <span class="bg-clip-text text-transparent bg-gradient-to-r from-slate-900 to-blue-600">KULAN</span><span class="text-blue-600">.</span>
</a>
        <div class="hidden lg:flex space-x-8 text-sm font-semibold tracking-wide text-slate-600">
          <a href="#about" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Profile</a>
          <a href="#experience" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Experience</a>
          <a href="#education" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Education</a>
          <a href="#projects" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Projects</a>
          <a href="#skills" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Skills</a>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 px-6 max-w-7xl mx-auto min-h-[90vh] flex flex-col md:flex-row items-center justify-between gap-12">
      <div class="flex-1 animate-fade-in">
        <div class="inline-block px-4 py-1.5 mb-6 rounded-full bg-blue-100 text-blue-700 font-semibold text-sm tracking-wide shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 cursor-default">
          Associate Software Engineer @ AIA Sri Lanka
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
          Building robust <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">enterprise systems.</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-600 max-w-2xl mb-10 leading-relaxed">
          Specializing in API engineering, Azure cloud services, and full-stack application development to deliver scalable, high-impact solutions.
        </p>
        <div class="flex flex-wrap gap-4 items-center">
          <a href="#projects" class="bg-slate-900 text-white px-8 py-3.5 rounded-xl font-semibold hover:bg-slate-800 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1">Explore My Work</a>
          <a href="#about" class="bg-white text-slate-900 border border-slate-200 px-8 py-3.5 rounded-xl font-semibold hover:border-slate-300 hover:bg-slate-50 transition-all hover:-translate-y-1">Read Profile</a>
        </div>
      </div>
      
      <!-- Profile Image -->
      <div class="flex-1 w-full max-w-md animate-fade-in delay-100">
        <div class="relative animate-float hover:scale-[1.03] transition-transform duration-500">
          <div class="absolute inset-0 bg-gradient-to-tr from-blue-500 to-cyan-400 rounded-3xl blur-2xl opacity-20 -z-10"></div>
          <img 
            src="/IMG_4435.JPG.jpeg" 
            alt="Kulan Thamuditha" 
            class="rounded-3xl shadow-2xl object-cover aspect-[4/5] w-full border border-white/50"
          />
        </div>
      </div>
    </section>

    <!-- Profile (About) Section -->
    <section id="about" class="py-24 px-6 bg-white border-t border-slate-100">
      <div class="max-w-4xl mx-auto text-center animate-fade-in delay-200">
        <h2 class="text-3xl font-extrabold mb-8 text-slate-900">Professional Profile</h2>
        <p class="text-lg text-slate-600 leading-relaxed text-left md:text-center glass-card p-8 rounded-3xl shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 card-float">
          Experienced Software Engineer with over one year of experience at AIA Sri Lanka, specializing in API engineering, technical support, Azure cloud services, and application development. Strong expertise in system design, modern frameworks, provider and data migrations, and application integrations. Holds a BSc (Hons) in Software Engineering from Cardiff Metropolitan University (UK). Highly proficient in automation and scripting, with a proven track record of delivering scalable solutions, improving release efficiency, and effectively supporting both development and application support teams.
        </p>
      </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="py-24 px-6 bg-slate-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-extrabold mb-12 flex items-center gap-3">
          <span class="w-2 h-8 bg-blue-600 rounded-full"></span> Professional Experience
        </h2>
        
        <div class="space-y-12 relative before:absolute before:inset-0 before:ml-2.5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-300 before:to-transparent">
          
          <!-- Job 1 -->
          <div class="relative pl-10 md:pl-0">
            <div class="md:w-1/2 md:pr-12 md:text-right md:ml-auto">
              <div class="absolute left-0 md:left-1/2 md:-ml-2.5 top-2 w-5 h-5 bg-blue-600 rounded-full border-4 border-slate-50 shadow"></div>
              <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-xl hover:-translate-y-1.5 hover:border-blue-200 transition-all duration-300 card-float delay-float-1">
                <h3 class="text-xl font-bold text-slate-900">Associate Software Engineer</h3>
                <p class="text-blue-600 font-medium mb-1">AIA Sri Lanka - IT Department</p>
                <p class="text-slate-500 text-sm mb-4">March 2026 - Present | AIA Tower, Colombo 7</p>
                <ul class="text-slate-600 text-sm space-y-2 text-left list-disc list-inside">
                  <li>Develop and maintain enterprise applications following coding standards.</li>
                  <li>Hands-on experience with Microsoft Power Platform for developing business applications and automating enterprise processes.</li>
                  <li>Maintain less than 5% bugs in the code.</li>
                  <li>Deliver L2/L3 BAU support for production incidents, adhering to SLA timelines to ensure 99% operational continuity.</li>
                  <li>Develop API integrations across enterprise systems (ESB).</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Job 2 -->
          <div class="relative pl-10 md:pl-0">
            <div class="md:w-1/2 md:pl-12">
              <div class="absolute left-0 md:left-1/2 md:-ml-2.5 top-2 w-5 h-5 bg-cyan-500 rounded-full border-4 border-slate-50 shadow"></div>
              <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-xl hover:-translate-y-1.5 hover:border-cyan-200 transition-all duration-300 card-float delay-float-2">
