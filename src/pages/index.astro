              </div>
              <div class="flex-1 text-center sm:text-left">
                <h3 class="font-bold text-slate-900 group-hover:text-blue-600 transition-colors">Full-Stack Engineer - AI Professional</h3>
                <p class="text-slate-500 text-xs mb-2">Conducted by STEM Link | 4 Months</p>
                <p class="text-slate-600 text-xs">MERN stack, LLMs, RAG pipelines, Vector DBs. Built Smart Hotel Discovery & Booking Platform.</p>
              </div>
            </div>
            
            <!-- Docker Certificate -->
            <div class="p-4 rounded-2xl bg-white border border-slate-200 hover:shadow-xl hover:scale-[1.02] hover:-translate-y-1 hover:border-blue-300 transition-all duration-300 group flex flex-col sm:flex-row gap-4 items-center card-float delay-float-1">
