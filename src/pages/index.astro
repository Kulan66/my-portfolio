              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-blue-50 transition-colors">Tailwind</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-blue-50 transition-colors">RAG</span>
