          </h2>
          <div class="grid gap-6">
            
            <!-- STEM Link Certificate -->
            <div class="p-4 rounded-2xl bg-white border border-slate-200 hover:shadow-xl hover:scale-[1.02] hover:-translate-y-1 hover:border-blue-300 transition-all duration-300 group flex flex-col sm:flex-row gap-4 items-center card-float delay-float-3">
              <div class="w-full sm:w-1/3 aspect-[4/3] rounded-lg overflow-hidden border border-slate-100 bg-slate-50 flex-shrink-0">
