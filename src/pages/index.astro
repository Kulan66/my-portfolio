              </div>
            </div>

            <!-- DS Senanayake -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 border border-slate-100 hover:border-cyan-200 hover:shadow-md hover:-translate-y-1 transition-all duration-300 card-float delay-float-2">
              <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSVLBawp8xNVsZZnqIv7NTXOap4oynFjSZ2Wg&s" alt="DSSC Crest" class="w-16 h-16 object-contain bg-white p-2 rounded-lg shadow-sm hover:scale-110 transition-transform duration-300" />
