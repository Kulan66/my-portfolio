</section>

<!-- 🌟 ANIMATION STYLES -->
<style>
  /* NEW BLOB ANIMATIONS */
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 10s infinite alternate ease-in-out;
  }
  .animation-delay-2000 { 
    animation-delay: 2s; 
  }
  .animation-delay-4000 { 
    animation-delay: 4s; 
  }

  /* STARS ANIMATIONS */
  .stars-small, .stars-medium, .stars-glow {
    position: absolute;
    width: 200%;
    height: 200%;
    background-repeat: repeat;
    animation: moveStars 140s linear infinite;
  }

  .stars-small {
    background-image: radial-gradient(1px 1px at 20px 30px, #94a3b8, transparent),
                      radial-gradient(1px 1px at 80px 120px, #cbd5e1, transparent),
                      radial-gradient(1px 1px at 160px 200px, #e2e8f0, transparent);
    background-size: 220px 220px;
    opacity: 0.55;
  }

  .stars-medium {
    background-image: radial-gradient(2px 2px at 50px 80px, #60a5fa, transparent),
                      radial-gradient(2px 2px at 140px 160px, #38bdf8, transparent);
    background-size: 320px 320px;
    animation-duration: 200s;
    opacity: 0.45;
  }

  .stars-glow {
    background-image: radial-gradient(circle at 100px 100px, rgba(56,189,248,0.8), transparent 40%),
                      radial-gradient(circle at 200px 250px, rgba(99,102,241,0.6), transparent 45%);
    filter: blur(1px);
    animation-duration: 260s;
    opacity: 0.3;
  }

  @keyframes moveStars {
    from { transform: translateY(0px); }
    to { transform: translateY(-1200px); }
  }

  /* floating animation */
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }
</style>

