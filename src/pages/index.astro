                <div class="mt-4 border-t border-slate-200 pt-4">
                  <h3 class="font-bold text-lg text-slate-900">G.C.E. Ordinary Level</h3>
                  <p class="text-slate-600 text-sm">D.S. Senanayake College</p>
                  <p class="text-slate-500 text-xs mt-1">2019 | Colombo 7 | Index: 90123930</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Certifications -->
        <div>
          <h2 class="text-3xl font-extrabold mb-10 flex items-center gap-3">
