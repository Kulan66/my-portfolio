---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kulan Thamuditha | Software Engineer</title>
    <style>
      /* Custom Animations */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-12px); }
        100% { transform: translateY(0px); }
      }
      .animate-fade-in {
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      .animate-float {
        animation: float 6s ease-in-out infinite;
      }
      .delay-100 { animation-delay: 100ms; }
      .delay-200 { animation-delay: 200ms; }
      .delay-300 { animation-delay: 300ms; }
      .delay-400 { animation-delay: 400ms; }
      
      /* Glassmorphism utilities */
      .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.5);
      }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased selection:bg-blue-200 selection:text-blue-900">
    
    <!-- Navigation -->
    <nav class="fixed w-full bg-white/80 backdrop-blur-lg border-b border-slate-200 z-50 transition-all duration-300">
      <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="#" class="text-2xl font-black tracking-tighter text-slate-900 hover:scale-105 transition-transform duration-300">KULAN<span class="text-blue-600">.</span></a>
        <div class="hidden lg:flex space-x-8 text-sm font-semibold tracking-wide text-slate-600">
          <a href="#about" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Profile</a>
          <a href="#experience" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Experience</a>
          <a href="#education" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Education</a>
          <a href="#projects" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Projects</a>
          <a href="#skills" class="hover:text-blue-600 hover:-translate-y-0.5 transition-all duration-300 inline-block">Skills</a>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 px-6 max-w-7xl mx-auto min-h-[90vh] flex flex-col md:flex-row items-center justify-between gap-12">
      <div class="flex-1 animate-fade-in">
        <div class="inline-block px-4 py-1.5 mb-6 rounded-full bg-blue-100 text-blue-700 font-semibold text-sm tracking-wide shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 cursor-default">
          Associate Software Engineer @ AIA Sri Lanka
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
          Building robust <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">enterprise systems.</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-600 max-w-2xl mb-10 leading-relaxed">
          Specializing in API engineering, Azure cloud services, and full-stack application development to deliver scalable, high-impact solutions.
        </p>
        <div class="flex flex-wrap gap-4 items-center">
          <a href="#projects" class="bg-slate-900 text-white px-8 py-3.5 rounded-xl font-semibold hover:bg-slate-800 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1">Explore My Work</a>
          <a href="#about" class="bg-white text-slate-900 border border-slate-200 px-8 py-3.5 rounded-xl font-semibold hover:border-slate-300 hover:bg-slate-50 transition-all hover:-translate-y-1">Read Profile</a>
        </div>
      </div>
      
      <!-- Profile Image -->
      <div class="flex-1 w-full max-w-md animate-fade-in delay-100">
        <div class="relative animate-float hover:scale-[1.03] transition-transform duration-500">
          <div class="absolute inset-0 bg-gradient-to-tr from-blue-500 to-cyan-400 rounded-3xl blur-2xl opacity-20 -z-10"></div>
          <img 
            src="/IMG_4435.JPG.jpeg" 
            alt="Kulan Thamuditha" 
            class="rounded-3xl shadow-2xl object-cover aspect-[4/5] w-full border border-white/50"
          />
        </div>
      </div>
    </section>

    <!-- Profile (About) Section -->
    <section id="about" class="py-24 px-6 bg-white border-t border-slate-100">
      <div class="max-w-4xl mx-auto text-center animate-fade-in delay-200">
        <h2 class="text-3xl font-extrabold mb-8 text-slate-900">Professional Profile</h2>
        <p class="text-lg text-slate-600 leading-relaxed text-left md:text-center glass-card p-8 rounded-3xl shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          Experienced Software Engineer with over one year of experience at AIA Sri Lanka, specializing in API engineering, technical support, Azure cloud services, and application development. Strong expertise in system design, modern frameworks, provider and data migrations, and application integrations. Holds a BSc (Hons) in Software Engineering from Cardiff Metropolitan University (UK). Highly proficient in automation and scripting, with a proven track record of delivering scalable solutions, improving release efficiency, and effectively supporting both development and application support teams.
        </p>
      </div>
    </section>

    <!-- Experience Section (LinkedIn Style Timeline) -->
    <section id="experience" class="py-24 px-6 bg-slate-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-extrabold mb-12 flex items-center gap-3">
          <span class="w-2 h-8 bg-blue-600 rounded-full"></span> Professional Experience
        </h2>
        
        <div class="group bg-white p-8 md:p-10 rounded-3xl shadow-sm border border-slate-200 hover:shadow-2xl hover:scale-[1.01] hover:-translate-y-1.5 hover:border-red-200 transition-all duration-500 relative overflow-hidden">
          
          <!-- Decorative left gradient line on hover -->
          <div class="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-[#D31145] to-red-400 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Company Header -->
          <div class="flex gap-5 items-start mb-6">
            <!-- AIA Logo -->
            <div class="flex-shrink-0 z-10">
              <div class="w-14 h-14 rounded-lg bg-[#D31145] flex items-center justify-center group-hover:scale-110 shadow-sm transition-transform duration-500 overflow-hidden border border-slate-100">
                <span class="text-xl font-black text-white tracking-tighter">AIA</span>
              </div>
            </div>
            <!-- Company Info -->
            <div class="pt-0.5">
              <h3 class="text-xl md:text-2xl font-bold text-slate-900">AIA Sri Lanka</h3>
              <p class="text-slate-600 text-sm md:text-base mt-0.5">1 yr 5 mos</p>
              <p class="text-slate-500 text-sm mt-0.5">Colombo, Western Province, Sri Lanka · On-site</p>
            </div>
          </div>

          <!-- Vertical Timeline -->
          <div class="ml-[27px] border-l-2 border-slate-200">
            
            <!-- Role 1: Associate SE -->
            <div class="relative pl-8 pb-10">
              <!-- Timeline Dot -->
              <div class="absolute w-3 h-3 bg-slate-300 rounded-full -left-[7px] top-2 group-hover:bg-[#D31145] transition-colors duration-500 shadow-[0_0_0_4px_white]"></div>
              
              <h4 class="text-lg md:text-xl font-bold text-slate-900 group-hover:text-[#D31145] transition-colors duration-300">Associate Software Engineer</h4>
              <p class="text-slate-700 text-sm mt-0.5">Full-time</p>
              <p class="text-slate-500 text-sm mt-0.5 mb-4">Mar 2026 - Present · 3 mos</p>
              
              <ul class="text-slate-600 text-sm md:text-base space-y-2 list-none">
                <li class="relative pl-4 before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-slate-400 before:rounded-full group-hover:before:bg-blue-500 transition-colors duration-300">
                  Develop and maintain enterprise applications following coding standards. Hands on experience with Microsoft Power Platform for developing business applications and automating enterprise processes.
                </li>
                <li class="relative pl-4 before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-slate-400 before:rounded-full group-hover:before:bg-blue-500 transition-colors duration-300">
                  Maintain less than 5% bugs in the code.
                </li>
                <li class="relative pl-4 before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-slate-400 before:rounded-full group-hover:before:bg-blue-500 transition-colors duration-300">
                  Deliver L2/L3 BAU support for production incidents, adhering to SLA timelines to ensure 99% operational continuity.
                </li>
                <li class="relative pl-4 before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-slate-400 before:rounded-full group-hover:before:bg-blue-500 transition-colors duration-300">
                  Develop API integrations across enterprise systems (ESB).
                </li>
              </ul>
            </div>

            <!-- Role 2: Intern -->
            <div class="relative pl-8">
              <!-- Timeline Dot -->
              <div class="absolute w-3 h-3 bg-slate-300 rounded-full -left-[7px] top-2 group-hover:bg-[#D31145] transition-colors duration-500 shadow-[0_0_0_4px_white]"></div>
              
              <h4 class="text-lg md:text-xl font-bold text-slate-900 group-hover:text-[#D31145] transition-colors duration-300">Software Engineer Intern</h4>
              <p class="text-slate-700 text-sm mt-0.5">Internship</p>
              <p class="text-slate-500 text-sm mt-0.5 mb-4">Jan 2025 - Feb 2026 · 1 yr 2 mos</p>
              
              <ul class="text-slate-600 text-sm md:text-base space-y-2 list-none mb-6">
                <li class="relative pl-4 before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-slate-400 before:rounded-full group-hover:before:bg-cyan-500 transition-colors duration-300">
                  Engineered RESTful & GraphQL APIs in Software AG Designer using IBM DB2/SQL within ESB Linux systems; remediated security vulnerabilities via Veracode scans and automated file transfers with SFTP scripts.
                </li>
                <li class="relative pl-4 before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-slate-400 before:rounded-full group-hover:before:bg-cyan-500 transition-colors duration-300">
                  Executed full SDLC using JAVA, Python, and PowerShell; managed deployments, version control (Bitbucket), UAT, Azure cloud services, and OKTA CIAM and Workforce configuration.
                </li>
                <li class="relative pl-4 before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-slate-400 before:rounded-full group-hover:before:bg-cyan-500 transition-colors duration-300">
                  Provided L2 Technical Support for SQL databases and real-time Workflow issues; managed vendor liaison, POC development, Agile-based CRs using Jira, and maintained technical documentation.
                </li>
              </ul>
              
              <!-- Skills Footer -->
              <div class="flex items-start gap-3 mt-2">
                <svg class="w-4 h-4 text-slate-500 flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2.7 10.3a2.41 2.41 0 0 0 0 3.41l7.59 7.59a2.41 2.41 0 0 0 3.42 0l7.59-7.59a2.41 2.41 0 0 0 0-3.41l-7.59-7.59a2.41 2.41 0 0 0-3.42 0Z"></path>
                </svg>
                <p class="text-sm font-semibold text-slate-800">
                  Application Programming Interfaces (API), Software Development and +4 skills
                </p>
              </div>

            </div>
          </div>
          
        </div>
      </div>
    </section>

    <!-- Education & Certifications Section -->
    <section id="education" class="py-24 px-6 bg-white border-y border-slate-100">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16">
        
        <!-- Education -->
        <div>
          <h2 class="text-3xl font-extrabold mb-10 flex items-center gap-3">
            <span class="w-2 h-8 bg-blue-600 rounded-full"></span> Education
          </h2>
          <div class="space-y-6">
            <!-- Cardiff Met Degrees -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 border border-slate-100 hover:border-blue-200 hover:shadow-md hover:-translate-y-1 transition-all duration-300">
              <img src="https://upload.wikimedia.org/wikipedia/en/e/ef/Cardiff_Metropolitan_University_logo.svg" alt="Cardiff Met Logo" class="w-16 h-16 object-contain bg-white p-2 rounded-lg shadow-sm hover:scale-110 transition-transform duration-300" />
              <div>
                <h3 class="font-bold text-lg text-slate-900">BSc (Hons) Software Engineering</h3>
                <p class="text-slate-600 text-sm">Cardiff Metropolitan University (ICBT Campus)</p>
                <p class="text-slate-500 text-xs mt-1">Nov 2024 - Nov 2025 | Colombo 4</p>
                <div class="mt-4 border-t border-slate-200 pt-4">
                  <h3 class="font-bold text-lg text-slate-900">Higher National Diploma in Computing & SE</h3>
                  <p class="text-slate-600 text-sm">Cardiff Metropolitan University (ICBT Campus)</p>
                  <p class="text-slate-500 text-xs mt-1">March 2023 - Oct 2024 | Colombo 4</p>
                </div>
              </div>
            </div>

            <!-- DS Senanayake -->
            <div class="flex items-start gap-4 p-6 rounded-2xl bg-slate-50 border border-slate-100 hover:border-cyan-200 hover:shadow-md hover:-translate-y-1 transition-all duration-300">
              <img src="https://upload.wikimedia.org/wikipedia/en/0/02/D_S_Senanayake_College_Crest.png" alt="DSSC Crest" class="w-16 h-16 object-contain bg-white p-2 rounded-lg shadow-sm hover:scale-110 transition-transform duration-300" />
              <div>
                <h3 class="font-bold text-lg text-slate-900">G.C.E. Advanced Level</h3>
                <p class="text-slate-600 text-sm">D.S. Senanayake College</p>
                <p class="text-slate-500 text-xs mt-1 mb-2">2022 (2023) | Colombo 7 | Index: 2091240</p>
                <p class="text-sm font-medium text-slate-700 bg-white inline-block px-3 py-1 rounded-md border border-slate-200">Geography: B | Logic: B | ICT: C</p>
                
                <div class="mt-4 border-t border-slate-200 pt-4">
                  <h3 class="font-bold text-lg text-slate-900">G.C.E. Ordinary Level</h3>
                  <p class="text-slate-600 text-sm">D.S. Senanayake College</p>
                  <p class="text-slate-500 text-xs mt-1">2019 | Colombo 7 | Index: 90123930</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Certifications -->
        <div>
          <h2 class="text-3xl font-extrabold mb-10 flex items-center gap-3">
            <span class="w-2 h-8 bg-cyan-500 rounded-full"></span> Professional Certificates
          </h2>
          <div class="grid gap-6">
            
            <!-- STEM Link Certificate -->
            <div class="p-4 rounded-2xl bg-white border border-slate-200 hover:shadow-xl hover:scale-[1.02] hover:-translate-y-1 hover:border-blue-300 transition-all duration-300 group flex flex-col sm:flex-row gap-4 items-center">
              <div class="w-full sm:w-1/3 aspect-[4/3] rounded-lg overflow-hidden border border-slate-100 bg-slate-50 flex-shrink-0">
                <img src="/cert-stemlink.jpg" alt="STEM Link Certificate" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="flex-1 text-center sm:text-left">
                <h3 class="font-bold text-slate-900 group-hover:text-blue-600 transition-colors">Full-Stack Engineer - AI Professional</h3>
                <p class="text-slate-500 text-xs mb-2">Conducted by STEM Link | 4 Months</p>
                <p class="text-slate-600 text-xs">MERN stack, LLMs, RAG pipelines, Vector DBs. Built Smart Hotel Discovery & Booking Platform.</p>
              </div>
            </div>
            
            <!-- Docker Certificate -->
            <div class="p-4 rounded-2xl bg-white border border-slate-200 hover:shadow-xl hover:scale-[1.02] hover:-translate-y-1 hover:border-blue-300 transition-all duration-300 group flex flex-col sm:flex-row gap-4 items-center">
              <div class="w-full sm:w-1/3 aspect-[4/3] rounded-lg overflow-hidden border border-slate-100 bg-slate-50 flex-shrink-0">
                <img src="/cert-docker.jpg" alt="Docker Certificate" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="flex-1 text-center sm:text-left">
                <h3 class="font-bold text-slate-900 group-hover:text-blue-600 transition-colors">Docker Foundations Professional</h3>
                <p class="text-slate-500 text-xs mb-2">LinkedIn Learning & Docker</p>
                <p class="text-slate-600 text-xs">Demonstrating proficiency in containerization and core Docker products.</p>
              </div>
            </div>

            <!-- Azure Certificate -->
            <div class="p-4 rounded-2xl bg-white border border-slate-200 hover:shadow-xl hover:scale-[1.02] hover:-translate-y-1 hover:border-blue-300 transition-all duration-300 group flex flex-col sm:flex-row gap-4 items-center">
              <div class="w-full sm:w-1/3 aspect-[4/3] rounded-lg overflow-hidden border border-slate-100 bg-slate-50 flex-shrink-0">
                <img src="/cert-azure.jpg" alt="Azure Certificate" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="flex-1 text-center sm:text-left">
                <h3 class="font-bold text-slate-900 group-hover:text-blue-600 transition-colors">Microsoft Azure Fundamentals (AZ-900)</h3>
                <p class="text-slate-500 text-xs mb-2">LinkedIn Learning / Microsoft Press</p>
                <p class="text-slate-600 text-xs">Foundational knowledge of Microsoft Azure cloud services and data governance.</p>
              </div>
            </div>

            <!-- Dataverse Certificate -->
            <div class="p-4 rounded-2xl bg-white border border-slate-200 hover:shadow-xl hover:scale-[1.02] hover:-translate-y-1 hover:border-blue-300 transition-all duration-300 group flex flex-col sm:flex-row gap-4 items-center">
              <div class="w-full sm:w-1/3 aspect-[4/3] rounded-lg overflow-hidden border border-slate-100 bg-slate-50 flex-shrink-0">
                <img src="/cert-dataverse.jpg" alt="Dataverse Certificate" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="flex-1 text-center sm:text-left">
                <h3 class="font-bold text-slate-900 group-hover:text-blue-600 transition-colors">Microsoft Dataverse for Power Apps / Automate</h3>
                <p class="text-slate-500 text-xs mb-2">Udemy | Date: May 4, 2026</p>
                <p class="text-slate-600 text-xs">Advanced data structures, automation, and integrations within the Microsoft Power Platform ecosystem.</p>
              </div>
            </div>

            <!-- NIBM (No Image Provided) -->
            <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 hover:shadow-md hover:-translate-y-1 hover:border-blue-200 transition-all duration-300">
              <h3 class="font-bold text-slate-900 mb-1">Advanced Certificate in English Language</h3>
              <p class="text-slate-500 text-sm">National Institute of Business Management (NIBM)</p>
            </div>

          </div>
        </div>
        
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="py-24 px-6 bg-slate-50">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-extrabold text-slate-900 mb-4">Featured Projects</h2>
          <p class="text-lg text-slate-600">Showcasing my expertise in full-stack development and AI integrations.</p>
        </div>
        
        <div class="grid lg:grid-cols-3 gap-8">
          <!-- Project 1 -->
          <div class="group bg-white rounded-3xl p-8 shadow-sm border border-slate-200 hover:shadow-2xl hover:scale-[1.03] hover:-translate-y-2 hover:border-blue-400 transition-all duration-300 flex flex-col h-full">
            <h3 class="text-xl font-bold text-slate-900 mb-2 leading-snug">Smart Hotel Discovery and Booking Platform</h3>
            <p class="text-blue-600 text-xs font-bold mb-4 uppercase tracking-wider">Full-Stack AI Certification Project</p>
            <p class="text-slate-600 text-sm mb-6 flex-grow">Built an intelligent hotel discovery and booking platform with personalized filtering and real-time availability.</p>
            <div class="flex flex-wrap gap-2 mt-auto">
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-blue-50 transition-colors">MERN</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-blue-50 transition-colors">OpenAI (LLMs)</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-blue-50 transition-colors">Langchain</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-blue-50 transition-colors">Vector DBs</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-blue-50 transition-colors">Tailwind</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-blue-50 transition-colors">RAG</span>
            </div>
          </div>

          <!-- Project 2 -->
          <div class="group bg-white rounded-3xl p-8 shadow-sm border border-slate-200 hover:shadow-2xl hover:scale-[1.03] hover:-translate-y-2 hover:border-cyan-400 transition-all duration-300 flex flex-col h-full">
            <h3 class="text-xl font-bold text-slate-900 mb-2 leading-snug">AI Life Insurance Product Recommendations</h3>
            <p class="text-cyan-600 text-xs font-bold mb-4 uppercase tracking-wider">BSc Final Year Project</p>
            <p class="text-slate-600 text-sm mb-6 flex-grow">Developed a web-based platform recommending personalized life insurance products using an AI agent, AI chat bot and customer profiling.</p>
            <div class="flex flex-wrap gap-2 mt-auto">
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-cyan-50 transition-colors">Python (Flask)</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-cyan-50 transition-colors">React.js</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-cyan-50 transition-colors">Scikit-learn</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-cyan-50 transition-colors">Random Forest</span>
              <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md group-hover:bg-cyan-50 transition-colors">XGBoost</span>
            </div>
          </div>

          <!-- Project 3 -->
          <div class="group bg-white rounded-3xl p-8 shadow-sm border border-slate-200 hover:shadow-2xl hover:scale-[1.03] hover:-translate-y-2 hover:border-indigo-400 transition-all duration-300 flex flex-col h-full">
            <h3 class="text-xl font-bold text-slate-900 mb-2 leading-snug">Mobile App Development Project</h3>
            <p class="text-indigo-600 text-xs font-bold mb-4 uppercase tracking-wider">HND Final Project</p>
            <p class="text-slate-600 text-sm mb-6 flex-grow">Built a mobile app that helps dog owners discover nutritional information and dog food products using Object-Oriented Programming (OOP) concepts.</p>
