            <div class="p-4 rounded-2xl bg-white border border-slate-200 hover:shadow-xl hover:scale-[1.02] hover:-translate-y-1 hover:border-blue-300 transition-all duration-300 group flex flex-col sm:flex-row gap-4 items-center card-float delay-float-2">
