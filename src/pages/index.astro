---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kulan Thamuditha | Software Engineer</title>
    <style>
      /* Custom Animations */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in {
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      .delay-100 { animation-delay: 100ms; }
      .delay-200 { animation-delay: 200ms; }
      .delay-300 { animation-delay: 300ms; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased selection:bg-blue-200 selection:text-blue-900">
    
    <!-- Navigation -->
    <nav class="fixed w-full bg-white/70 backdrop-blur-lg border-b border-slate-200 z-50 transition-all duration-300">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="#" class="text-2xl font-black tracking-tighter text-slate-900">KULAN<span class="text-blue-600">.</span></a>
        <div class="hidden md:flex space-x-8 text-sm font-semibold tracking-wide text-slate-600">
          <a href="#about" class="hover:text-blue-600 transition-colors">About</a>
          <a href="#experience" class="hover:text-blue-600 transition-colors">Experience</a>
          <a href="#projects" class="hover:text-blue-600 transition-colors">Projects</a>
          <a href="#contact" class="hover:text-blue-600 transition-colors">Contact</a>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 px-6 max-w-6xl mx-auto min-h-[90vh] flex flex-col md:flex-row items-center justify-between gap-12">
      <div class="flex-1 animate-fade-in">
        <div class="inline-block px-4 py-1.5 mb-6 rounded-full bg-blue-100 text-blue-700 font-semibold text-sm tracking-wide">
          Associate Software Engineer
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
          Building robust <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">enterprise systems.</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-600 max-w-xl mb-10 leading-relaxed">
          I'm Kulan Thamuditha, a Software Engineer specializing in API engineering, Azure cloud services, and AI integrations. Based in Colombo, Sri Lanka.
        </p>
        <div class="flex flex-wrap gap-4 items-center">
          <a href="#projects" class="bg-slate-900 text-white px-8 py-3.5 rounded-xl font-semibold hover:bg-slate-800 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">Explore My Work</a>
          <a href="https://linkedin.com/in/kulanthamuditha" target="_blank" class="flex items-center gap-2 bg-white text-slate-900 border border-slate-200 px-8 py-3.5 rounded-xl font-semibold hover:border-slate-300 hover:bg-slate-50 transition-all">
            <svg class="w-5 h-5 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            Connect
          </a>
        </div>
      </div>
      
      <!-- Profile Image -->
      <div class="flex-1 w-full max-w-md animate-fade-in delay-100">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-tr from-blue-500 to-cyan-400 rounded-3xl blur-2xl opacity-20 -z-10"></div>
          <img 
            src="/IMG_4435.JPG.jpeg" 
            alt="Kulan Thamuditha" 
            class="rounded-3xl shadow-2xl object-cover aspect-[4/5] w-full border border-white/50"
          />
        </div>
      </div>
    </section>

    <!-- Experience & Education Section -->
    <section id="experience" class="py-24 px-6 bg-white border-y border-slate-100">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16">
        
        <!-- Experience -->
        <div class="animate-fade-in delay-200">
          <h2 class="text-3xl font-extrabold mb-10 flex items-center gap-3">
            <span class="w-2 h-8 bg-blue-600 rounded-full"></span> Professional Experience
          </h2>
          <div class="space-y-10 relative before:absolute before:inset-0 before:ml-2.5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-200 before:to-transparent">
            
            <div class="relative pl-10">
              <div class="absolute left-0 top-2 w-5 h-5 bg-blue-600 rounded-full border-4 border-white shadow"></div>
              <h3 class="text-xl font-bold text-slate-900">Associate Software Engineer</h3>
              <p class="text-blue-600 font-medium mb-3">AIA Sri Lanka • March 2026 - Present</p>
              <p class="text-slate-600 leading-relaxed">Developing and maintaining enterprise applications using Microsoft Power Platform. Delivering L2/L3 BAU support and engineering API integrations across ESB systems to ensure 99% operational continuity.</p>
            </div>

            <div class="relative pl-10">
              <div class="absolute left-0 top-2 w-5 h-5 bg-slate-300 rounded-full border-4 border-white shadow"></div>
              <h3 class="text-xl font-bold text-slate-900">Software Engineering Intern</h3>
              <p class="text-slate-500 font-medium mb-3">AIA Sri Lanka • Jan 2025 - Feb 2026</p>
              <p class="text-slate-600 leading-relaxed">Engineered RESTful & GraphQL APIs in Software AG Designer. Executed full SDLC utilizing Java, Python, and Azure cloud services while managing vendor relations and POC development.</p>
            </div>
          </div>
        </div>

        <!-- Education & Certs -->
        <div class="animate-fade-in delay-300">
          <h2 class="text-3xl font-extrabold mb-10 flex items-center gap-3">
            <span class="w-2 h-8 bg-cyan-500 rounded-full"></span> Education & Credentials
          </h2>
          <div class="space-y-6">
            <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 hover:border-blue-200 hover:shadow-md transition-all">
              <h3 class="font-bold text-lg text-slate-900">BSc (Hons) Software Engineering</h3>
              <p class="text-slate-600 text-sm mt-1">Cardiff Metropolitan University • Second Class, Division One</p>
            </div>
            
            <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 hover:border-blue-200 hover:shadow-md transition-all">
              <h3 class="font-bold text-lg text-slate-900">Full-Stack Engineer - AI Certification</h3>
              <p class="text-slate-600 text-sm mt-1">STEM Link • MERN Stack, LLMs, RAG Pipelines</p>
            </div>

            <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 hover:border-blue-200 hover:shadow-md transition-all">
              <h3 class="font-bold text-lg text-slate-900">Microsoft Azure Fundamentals (AZ-900)</h3>
              <p class="text-slate-600 text-sm mt-1">LinkedIn Learning / Microsoft Press</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="py-24 px-6 bg-slate-50">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-extrabold text-slate-900 mb-4">Featured Projects</h2>
          <p class="text-lg text-slate-600">Showcasing my expertise in AI integrations and full-stack development.</p>
        </div>
        
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Project 1 -->
          <div class="group bg-white rounded-3xl p-8 shadow-sm border border-slate-200 hover:shadow-xl hover:border-blue-300 transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-3">Smart Hotel Discovery Platform</h3>
            <p class="text-slate-600 mb-6 leading-relaxed">An intelligent booking platform built with the MERN stack featuring personalized filtering and real-time availability using OpenAI LLMs, Langchain, and Vector Databases.</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-lg">React</span>
              <span class="px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-lg">Node.js</span>
              <span class="px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-lg">OpenAI</span>
            </div>
          </div>

          <!-- Project 2 -->
          <div class="group bg-white rounded-3xl p-8 shadow-sm border border-slate-200 hover:shadow-xl hover:cyan-300 transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-cyan-100 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-3">AI Life Insurance Recommender</h3>
            <p class="text-slate-600 mb-6 leading-relaxed">Developed a web-based platform recommending personalized life insurance products utilizing an AI agent and customer risk profiling through machine learning models.</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-lg">Python (Flask)</span>
              <span class="px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-lg">Scikit-learn</span>
              <span class="px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-lg">React.js</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact & Footer -->
    <section id="contact" class="py-24 px-6 bg-slate-900 text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl font-extrabold mb-6">Let's Connect</h2>
        <p class="text-slate-400 mb-10 text-xl font-light">
          Currently open to discussing new opportunities, enterprise architecture, or modern web development projects.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="mailto:kulanthamuditha66@gmail.com" class="bg-blue-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-500 transition-colors shadow-lg hover:shadow-blue-500/25">
            Email Me
          </a>
          <a href="https://github.com/kulan66" target="_blank" class="bg-white/10 backdrop-blur-sm text-white border border-white/20 px-8 py-4 rounded-xl font-bold hover:bg-white/20 transition-colors">
            GitHub
          </a>
        </div>
      </div>
    </section>

    <footer class="bg-slate-950 py-8 text-center border-t border-white/10">
      <p class="text-slate-500 text-sm font-medium">&copy; {new Date().getFullYear()} Kulan Thamuditha. Built with Astro & Tailwind CSS.</p>
    </footer>

  </body>
</html>